# Для dev: оставить пустым или localhost:8080 — запросы идут через proxy
# Для prod: URL бэкенда (например https://api.example.com)
REACT_APP_API_URL=http://localhost:8080

# WebSocket URL (опционально). По умолчанию: в production — origin/ws (nginx), локально — API_BASE/ws
# REACT_APP_WS_URL=https://lotus.baxic.ru/ws
